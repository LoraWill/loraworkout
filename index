<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lora's Workouts</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root {
    /* Williams Law Office color palette — navy, gold, cream, white */
    --navy:       #1B2A4A;
    --navy-dark:  #111D33;
    --navy-deep:  #0D1626;
    --navy-mid:   #243354;
    --navy-light: #2E4270;
    --gold:       #B89C5E;
    --gold-dim:   #8C7545;
    --gold-bright:#D4B97A;
    --cream:      #F5F0E8;
    --cream-dim:  #E8E0CE;
    --text:       #F0EBE0;
    --text-dim:   #8A9BBB;
    --danger:     #C0392B;
    --green:      #27AE60;
    --green-dark: #1E8449;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--navy-deep);
    color: var(--text);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HEADER */
  .header {
    background: var(--navy-dark);
    border-bottom: 2px solid var(--gold);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-left {
    display: flex;
    flex-direction: column;
  }

  .header-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    color: var(--gold);
    letter-spacing: 2px;
    line-height: 1;
  }

  .header-date {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .hamburger {
    background: none;
    border: 1.5px solid var(--gold-dim);
    border-radius: 6px;
    padding: 8px 10px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 0.2s;
  }
  .hamburger:hover { border-color: var(--gold); }
  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--gold);
    border-radius: 2px;
    transition: background 0.2s;
  }

  /* CONTENT */
  .tab-content { display: block; padding: 20px; }

  /* WORKOUT TAB */
  .day-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--gold);
    letter-spacing: 3px;
    margin-bottom: 4px;
  }

  .day-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .workout-card {
    background: var(--navy-mid);
    border: 1px solid var(--navy-light);
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .workout-card-header {
    background: var(--navy-light);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .workout-card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--gold);
    text-transform: uppercase;
  }

  .exercise-row {
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .exercise-row:last-child { border-bottom: none; }

  .exercise-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }

  .exercise-name.main {
    color: var(--gold);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .exercise-sets {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 1px;
    white-space: nowrap;
    margin-left: 10px;
  }

  .cardio-card {
    background: linear-gradient(135deg, rgba(184,156,94,0.12) 0%, rgba(184,156,94,0.06) 100%);
    border: 1px solid var(--gold-dim);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .cardio-info { flex: 1; }

  .cardio-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--gold);
    letter-spacing: 2px;
  }

  .cardio-detail {
    font-size: 13px;
    color: var(--text-dim);
    margin-top: 2px;
  }

  .rest-day {
    text-align: center;
    padding: 40px 20px;
  }

  .rest-day .big {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    color: var(--gold);
    letter-spacing: 4px;
    line-height: 1;
  }

  .rest-day .sub {
    font-family: 'Barlow Condensed', sans-serif;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  /* QUICK SWAP BUTTONS */
  .quick-swap-row {
    display: flex;
    gap: 10px;
    margin-bottom: 18px;
  }

  .swap-btn {
    flex: 1;
    background: var(--navy-mid);
    border: 1.5px solid var(--navy-light);
    border-radius: 10px;
    padding: 10px 12px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .swap-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(184,156,94,0.08);
  }

  .swap-btn.active {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(184,156,94,0.12);
  }

  .swap-btn .swap-icon {
    display: block;
    font-size: 18px;
    margin-bottom: 3px;
  }

  /* MENU OVERLAY */
  .menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .menu-overlay.open { opacity: 1; pointer-events: all; }

  .menu-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 290px;
    height: 100vh;
    background: var(--navy-mid);
    border-left: 2px solid var(--gold);
    z-index: 201;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(.4,0,.2,1);
    display: flex;
    flex-direction: column;
  }

  .menu-drawer.open { transform: translateX(0); }

  .menu-header {
    padding: 20px;
    border-bottom: 1px solid var(--navy-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .menu-header-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--gold);
    letter-spacing: 2px;
  }

  .close-btn {
    background: none;
    border: 1px solid var(--navy-light);
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 18px;
    padding: 4px 10px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .close-btn:hover { border-color: var(--gold); color: var(--gold); }

  .menu-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
  }

  .menu-section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 10px;
    margin-top: 4px;
  }

  .week-day-btn {
    width: 100%;
    background: var(--navy-dark);
    border: 1px solid var(--navy-light);
    border-radius: 8px;
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 11px 14px;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 8px;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .week-day-btn:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }

  .week-day-btn .day-tag {
    font-size: 11px;
    color: var(--text-dim);
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .week-day-btn.rest-tag .day-tag { color: #4a5f80; }

  .menu-footer {
    padding: 16px;
    border-top: 1px solid var(--navy-light);
  }

  /* WORKOUT COMPLETE */
  .workout-done-wrap {
    padding: 20px 0 8px;
    display: flex;
    justify-content: center;
  }

  .workout-done-btn {
    background: rgba(39,174,96,0.15);
    border: 2px solid #27AE60;
    border-radius: 12px;
    color: #2ECC71;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    padding: 14px 40px;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s, border-color 0.2s;
  }
  .workout-done-btn:hover { background: rgba(39,174,96,0.25); border-color: #2ECC71; }

  .workout-complete-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(11, 24, 45, 0.97);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 150;
    animation: fadeInOverlay 0.4s ease;
  }

  .workout-complete-overlay.show { display: flex; }

  @keyframes fadeInOverlay {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }

  .complete-checkmark {
    font-size: 110px;
    color: #2ECC71;
    line-height: 1;
    animation: popIn 0.4s cubic-bezier(.4,0,.2,1);
  }

  @keyframes popIn {
    from { transform: scale(0.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .complete-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: #2ECC71;
    letter-spacing: 4px;
    margin-top: 10px;
  }

  .complete-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    color: rgba(46,204,113,0.7);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 6px;
  }

  .undo-btn {
    margin-top: 28px;
    background: none;
    border: 1px solid rgba(46,204,113,0.4);
    border-radius: 8px;
    color: rgba(46,204,113,0.7);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 20px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .undo-btn:hover { border-color: #2ECC71; color: #2ECC71; }

  #tab-workout {
    position: relative;
    min-height: 100vh;
  }

  .no-workout {
    background: var(--navy-mid);
    border: 1px solid var(--navy-light);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    color: var(--text-dim);
    text-align: center;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .slide-in { animation: slideIn 0.3s ease; }

  /* WEIGHT LOG */
  .exercise-row {
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  .exercise-row-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .weight-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .weight-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .weight-input {
    flex: 1;
    background: var(--navy-deep);
    border: 1px solid var(--navy-light);
    border-radius: 6px;
    padding: 5px 10px;
    color: var(--text);
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
    min-width: 0;
  }

  .weight-input::placeholder { color: #4a5f80; }
  .weight-input:focus { border-color: var(--gold-dim); }

  .weight-save-btn {
    background: var(--navy-light);
    border: 1px solid var(--gold-dim);
    border-radius: 6px;
    color: var(--gold);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 5px 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .weight-save-btn:hover { background: rgba(184,156,94,0.15); border-color: var(--gold); }
  .weight-save-btn.saved {
    color: #2ECC71;
    border-color: #27AE60;
    background: rgba(39,174,96,0.1);
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--navy-deep); }
  ::-webkit-scrollbar-thumb { background: var(--navy-light); border-radius: 3px; }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <div class="header-title">Lora's Workouts</div>
    <div class="header-date" id="headerDate"></div>
  </div>
  <button class="hamburger" onclick="openMenu()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</div>

<!-- WORKOUT TAB -->
<div class="tab-content" id="tab-workout">
  <div id="workoutContent"></div>
  <div class="workout-done-wrap" id="workoutDoneWrap" style="display:none">
    <button class="workout-done-btn" onclick="markWorkoutDone()">✓ Workout Complete</button>
  </div>
</div>

<!-- WORKOUT COMPLETE OVERLAY -->
<div class="workout-complete-overlay" id="workoutCompleteOverlay">
  <div class="complete-checkmark">✓</div>
  <div class="complete-label">Workout Done!</div>
  <div class="complete-sub">Keep crushing it, Lora</div>
  <button class="undo-btn" onclick="undoWorkoutDone()">Undo</button>
</div>

<!-- MENU OVERLAY -->
<div class="menu-overlay" id="menuOverlay" onclick="closeMenu()"></div>
<div class="menu-drawer" id="menuDrawer">
  <div class="menu-header">
    <div class="menu-header-title">Week View</div>
    <button class="close-btn" onclick="closeMenu()">✕</button>
  </div>
  <div class="menu-body">
    <div class="menu-section-title">Jump to a day</div>
    <button class="week-day-btn" onclick="previewDay(1); closeMenu()">
      <span>Monday</span><span class="day-tag">Back / Upper</span>
    </button>
    <button class="week-day-btn" onclick="previewDay(2); closeMenu()">
      <span>Tuesday</span><span class="day-tag">Lower / Glutes</span>
    </button>
    <button class="week-day-btn rest-tag" onclick="previewDay(3); closeMenu()">
      <span>Wednesday</span><span class="day-tag">Rest Day</span>
    </button>
    <button class="week-day-btn" onclick="previewDay(4); closeMenu()">
      <span>Thursday</span><span class="day-tag">Upper / Chest</span>
    </button>
    <button class="week-day-btn" onclick="previewDay(5); closeMenu()">
      <span>Friday</span><span class="day-tag">Lower / Glutes</span>
    </button>
    <button class="week-day-btn rest-tag" onclick="previewDay(6); closeMenu()">
      <span>Saturday</span><span class="day-tag">Rest Day</span>
    </button>
    <button class="week-day-btn rest-tag" onclick="previewDay(0); closeMenu()">
      <span>Sunday</span><span class="day-tag">Rest Day</span>
    </button>
  </div>
  <div class="menu-footer">
    <button class="week-day-btn" style="margin-bottom:0; border-color: var(--gold-dim); color: var(--gold);" onclick="goToToday(); closeMenu()">
      <span>↩ Back to Today</span><span class="day-tag">reset view</span>
    </button>
  </div>
</div>

<script>
  // ─────────────────────────────────────────────────
  //  WORKOUT DATA
  // ─────────────────────────────────────────────────

  const UPPER = {
    label: "UPPER WORKOUT",
    sub: "Back · Shoulders · Arms",
    cardio: true,
    exercises: [
      { name: "Lat Pull Down", sets: "3 × 10", main: true },
      { name: "Cable Row",     sets: "3 × 10" },
      { name: "Shoulder Press",sets: "3 × 10" },
      { name: "Lateral Raises",sets: "3 × 8"  },
    ]
  };

  const LOWER_BASE = [
    { name: "Hip Thrust",             sets: "3 × 8",         main: true },
    { name: "Walking Weighted Lunges",sets: "3 × 10 each leg"            },
    { name: "Leg Extensions",         sets: "3 × 10"                     },
  ];

  const LOWER_FRIDAY = [
    { name: "Hip Thrust",             sets: "3 × 8",         main: true },
    { name: "Walking Weighted Lunges",sets: "3 × 10 each leg"            },
    { name: "Leg Curl",               sets: "3 × 10"                     },
  ];

  const LOWER_FULL = [
    { name: "Hip Thrust",             sets: "3 × 8",         main: true },
    { name: "Walking Weighted Lunges",sets: "3 × 10 each leg"            },
    { name: "Leg Extensions",         sets: "3 × 10"                     },
    { name: "Leg Curl",               sets: "3 × 10"                     },
  ];

  const workouts = {
    1: { // Monday
      label: "MONDAY",
      sub: "Back · Shoulders · Arms",
      cardio: true,
      exercises: UPPER.exercises,
    },
    2: { // Tuesday
      label: "TUESDAY",
      sub: "Lower · Glutes · Legs",
      cardio: true,
      exercises: LOWER_BASE,
    },
    3: { label: "WEDNESDAY", sub: "Rest Day", rest: true },
    4: { // Thursday
      label: "THURSDAY",
      sub: "Upper · Chest · Arms",
      cardio: true,
      exercises: [
        { name: "Dumbbell Chest Press", sets: "3 × 10", main: true },
        { name: "Bicep Curls",          sets: "3 × 8"              },
        { name: "Tricep Pushdown",      sets: "3 × 10"             },
        { name: "Lateral Raises",       sets: "3 × 8"              },
      ]
    },
    5: { // Friday
      label: "FRIDAY",
      sub: "Lower · Glutes · Legs",
      cardio: true,
      exercises: LOWER_FRIDAY,
    },
    6: { label: "SATURDAY", sub: "Rest Day", rest: true },
    0: { label: "SUNDAY",   sub: "Rest Day", rest: true },
  };

  // ─────────────────────────────────────────────────
  //  STATE
  // ─────────────────────────────────────────────────

  let todayKey  = getTodayKey();
  let previewDow = null; // null = use today
  let activeSwap = null; // 'upper' | 'lower' | null

  // ─────────────────────────────────────────────────
  //  INDEXEDDB
  // ─────────────────────────────────────────────────

  const DB_NAME    = 'loraWorkoutsDB';
  const DB_VER     = 2;
  const DONE_STORE = 'workoutDone';
  const WT_STORE   = 'weights';
  let db = null;

  function openDB() {
    return new Promise((resolve, reject) => {
      if (db) { resolve(db); return; }
      const req = indexedDB.open(DB_NAME, DB_VER);
      req.onupgradeneeded = e => {
        const d = e.target.result;
        if (!d.objectStoreNames.contains(DONE_STORE))
          d.createObjectStore(DONE_STORE, { keyPath: 'date' });
        if (!d.objectStoreNames.contains(WT_STORE))
          d.createObjectStore(WT_STORE, { keyPath: 'exercise' });
      };
      req.onsuccess = e => { db = e.target.result; resolve(db); };
      req.onerror   = e => reject(e);
    });
  }

  function dbGetDone(date) {
    return openDB().then(d => new Promise((resolve) => {
      const tx  = d.transaction(DONE_STORE, 'readonly');
      const req = tx.objectStore(DONE_STORE).get(date);
      req.onsuccess = e => resolve(e.target.result ? e.target.result.done : false);
      req.onerror   = () => resolve(false);
    }));
  }

  function dbSetDone(date, done) {
    return openDB().then(d => new Promise((resolve, reject) => {
      const tx = d.transaction(DONE_STORE, 'readwrite');
      tx.objectStore(DONE_STORE).put({ date, done });
      tx.oncomplete = () => resolve();
      tx.onerror    = e => reject(e);
    }));
  }

  function dbGetWeight(exercise) {
    return openDB().then(d => new Promise((resolve) => {
      const tx  = d.transaction(WT_STORE, 'readonly');
      const req = tx.objectStore(WT_STORE).get(exercise);
      req.onsuccess = e => resolve(e.target.result ? e.target.result.weight : '');
      req.onerror   = () => resolve('');
    }));
  }

  function dbSetWeight(exercise, weight) {
    return openDB().then(d => new Promise((resolve, reject) => {
      const tx = d.transaction(WT_STORE, 'readwrite');
      tx.objectStore(WT_STORE).put({ exercise, weight });
      tx.oncomplete = () => resolve();
      tx.onerror    = e => reject(e);
    }));
  }

  function dbGetAllWeights() {
    return openDB().then(d => new Promise((resolve) => {
      const tx  = d.transaction(WT_STORE, 'readonly');
      const req = tx.objectStore(WT_STORE).getAll();
      req.onsuccess = e => {
        const map = {};
        (e.target.result || []).forEach(r => { map[r.exercise] = r.weight; });
        resolve(map);
      };
      req.onerror = () => resolve({});
    }));
  }

  // ─────────────────────────────────────────────────
  //  HELPERS
  // ─────────────────────────────────────────────────

  function getTodayKey() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }

  function setHeaderDate() {
    const now  = new Date();
    const opts = { weekday:'long', month:'long', day:'numeric', year:'numeric' };
    document.getElementById('headerDate').textContent =
      now.toLocaleDateString('en-US', opts).toUpperCase();
  }

  // ─────────────────────────────────────────────────
  //  QUICK-SWAP BUTTONS
  // ─────────────────────────────────────────────────

  function buildSwapButtons(dow) {
    return `
      <div class="quick-swap-row">
        <button class="swap-btn${activeSwap === 'upper' ? ' active' : ''}"
                onclick="setSwap('upper')" id="swapUpperBtn">
          <span class="swap-icon">💪</span>
          Upper Workout
        </button>
        <button class="swap-btn${activeSwap === 'lower' ? ' active' : ''}"
                onclick="setSwap('lower')" id="swapLowerBtn">
          <span class="swap-icon">🦵</span>
          Lower Workout
        </button>
      </div>
    `;
  }

  function setSwap(type) {
    if (activeSwap === type) {
      activeSwap = null; // toggle off
    } else {
      activeSwap = type;
    }
    renderWorkout();
  }

  // ─────────────────────────────────────────────────
  //  RENDER WORKOUT
  // ─────────────────────────────────────────────────

  async function renderWorkout() {
    const dow = previewDow !== null ? previewDow : new Date().getDay();
    const el  = document.getElementById('workoutContent');
    const doneWrap = document.getElementById('workoutDoneWrap');
    const overlay  = document.getElementById('workoutCompleteOverlay');

    const isToday = (previewDow === null);

    // Determine what workout to show
    let w;
    if (activeSwap === 'upper') {
      w = {
        label: "UPPER WORKOUT",
        sub: "Back · Shoulders · Arms (Quick Select)",
        cardio: true,
        exercises: UPPER.exercises,
      };
    } else if (activeSwap === 'lower') {
      w = {
        label: "LOWER WORKOUT",
        sub: "Glutes · Legs (Quick Select)",
        cardio: true,
        exercises: LOWER_FULL,
      };
    } else {
      w = workouts[dow];
    }

    if (!w) { el.innerHTML = ''; return; }

    if (w.rest && !activeSwap) {
      doneWrap.style.display = 'none';
      overlay.classList.remove('show');
      el.innerHTML = `
        ${buildSwapButtons(dow)}
        <div class="rest-day">
          <div class="big">REST DAY</div>
          <div class="sub">Recovery is part of the process</div>
        </div>
      `;
      return;
    }

    doneWrap.style.display = 'flex';

    // Restore done state (only relevant when viewing today)
    if (isToday) {
      try {
        const done = await dbGetDone(todayKey);
        if (done) overlay.classList.add('show');
        else overlay.classList.remove('show');
      } catch {}
    } else {
      overlay.classList.remove('show');
    }

    // Load all saved weights
    let weights = {};
    try { weights = await dbGetAllWeights(); } catch {}

    let html = buildSwapButtons(dow);

    if (previewDow !== null && previewDow !== new Date().getDay()) {
      const dayName = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][previewDow];
      html += `<div style="background:rgba(184,156,94,0.08);border:1px solid var(--gold-dim);border-radius:8px;padding:8px 14px;margin-bottom:14px;font-family:'Barlow Condensed',sans-serif;font-size:12px;color:var(--gold-dim);letter-spacing:1px;text-transform:uppercase;">Previewing ${dayName}'s workout</div>`;
    }

    html += `
      <div class="day-label slide-in">${w.label}</div>
      <div class="day-sub">${w.sub}</div>
    `;

    // Lifts card
    html += `<div class="workout-card"><div class="workout-card-header"><span class="workout-card-title">Lifts</span></div>`;
    w.exercises.forEach(ex => {
      const key = ex.name;
      const saved = weights[key] || '';
      const inputId = 'wt-' + key.replace(/\s+/g, '-').toLowerCase();
      const btnId   = 'wtbtn-' + key.replace(/\s+/g, '-').toLowerCase();
      html += `
        <div class="exercise-row">
          <div class="exercise-row-top">
            <div class="exercise-name${ex.main ? ' main' : ''}">${ex.name}${ex.main ? ' ★' : ''}</div>
            <div class="exercise-sets">${ex.sets}</div>
          </div>
          <div class="weight-row">
            <span class="weight-label">Last weight:</span>
            <input
              class="weight-input"
              id="${inputId}"
              type="text"
              placeholder="e.g. 45 lbs"
              value="${escHtml(saved)}"
              onkeydown="if(event.key==='Enter') saveWeight('${escHtml(key)}','${inputId}','${btnId}')"
            />
            <button
              class="weight-save-btn"
              id="${btnId}"
              onclick="saveWeight('${escHtml(key)}','${inputId}','${btnId}')"
            >Save</button>
          </div>
        </div>
      `;
    });
    html += `</div>`;

    // Cardio card
    if (w.cardio) {
      html += `
        <div class="cardio-card">
          <div class="cardio-info">
            <div class="cardio-title">🚶 Treadmill Walk</div>
            <div class="cardio-detail">20–30 minutes · steady pace</div>
          </div>
        </div>
      `;
    }

    el.innerHTML = html;
  }

  // ─────────────────────────────────────────────────
  //  WEIGHT SAVING
  // ─────────────────────────────────────────────────

  async function saveWeight(exercise, inputId, btnId) {
    const input = document.getElementById(inputId);
    const btn   = document.getElementById(btnId);
    if (!input || !btn) return;
    const val = input.value.trim();
    try {
      await dbSetWeight(exercise, val);
      btn.textContent = '✓ Saved';
      btn.classList.add('saved');
      setTimeout(() => {
        btn.textContent = 'Save';
        btn.classList.remove('saved');
      }, 1800);
    } catch {
      btn.textContent = 'Error';
      setTimeout(() => { btn.textContent = 'Save'; }, 1800);
    }
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  // ─────────────────────────────────────────────────
  //  ACTIONS
  // ─────────────────────────────────────────────────

  async function markWorkoutDone() {
    document.getElementById('workoutCompleteOverlay').classList.add('show');
    try { await dbSetDone(todayKey, true); } catch {}
  }

  async function undoWorkoutDone() {
    document.getElementById('workoutCompleteOverlay').classList.remove('show');
    try { await dbSetDone(todayKey, false); } catch {}
  }

  function previewDay(dow) {
    previewDow = dow;
    activeSwap = null;
    renderWorkout();
  }

  function goToToday() {
    previewDow = null;
    activeSwap = null;
    renderWorkout();
  }

  // ─────────────────────────────────────────────────
  //  MENU
  // ─────────────────────────────────────────────────

  function openMenu() {
    document.getElementById('menuOverlay').classList.add('open');
    document.getElementById('menuDrawer').classList.add('open');
  }

  function closeMenu() {
    document.getElementById('menuOverlay').classList.remove('open');
    document.getElementById('menuDrawer').classList.remove('open');
  }

  // ─────────────────────────────────────────────────
  //  MIDNIGHT RESET
  // ─────────────────────────────────────────────────

  let lastCheckedKey = todayKey;
  setInterval(() => {
    const currentKey = getTodayKey();
    if (currentKey !== lastCheckedKey) {
      lastCheckedKey = currentKey;
      todayKey       = currentKey;
      if (previewDow === null) renderWorkout();
    }
  }, 60000);

  // ─────────────────────────────────────────────────
  //  INIT
  // ─────────────────────────────────────────────────

  function init() {
    setHeaderDate();
    renderWorkout();
  }

  init();
</script>
</body>
</html>
